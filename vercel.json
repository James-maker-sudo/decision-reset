{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.jsx", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/DecisionReset.jsx", "dest": "/DecisionReset.jsx" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
